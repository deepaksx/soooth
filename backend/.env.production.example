# Soooth Production Environment Variables
# Copy this file and set actual values in Render dashboard

# API Keys
FAL_KEY=your_fal_ai_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# AWS S3 Configuration (REQUIRED for production)
AWS_ACCESS_KEY_ID=AKIA...your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=soooth-media-library
USE_S3_CACHE=true

# Database
DATABASE_URL=sqlite:///./soooth.db

# Media Directory (temp storage, S3 is primary)
MEDIA_DIR=/tmp/media
